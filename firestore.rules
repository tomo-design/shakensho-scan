rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){ return request.auth != null; }
    function isOwner(){ return signedIn() && request.auth.token.email == "banana19870729@gmail.com"; }
    function meDoc(){ return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function meActive(){ return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && meDoc().active == true; }
    function myTenant(){ return meActive() ? meDoc().tenantId : ""; }
    function myRole(){ return meActive() ? meDoc().role : ""; }
    function isSuper(){ return isOwner() || myRole() == "super"; }
    function isAdmin(){ return myRole() == "admin"; }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isSuper() || (isAdmin() && resource.data.tenantId == myTenant()));
      // オーナー本人は自分のドキュメントを自由に作成/更新可(super昇格のため)
      allow write: if request.auth.uid == uid && isOwner();
      // 一般の自己登録: active=false かつ role は admin/staff のみ
      allow create: if request.auth.uid == uid
                    && request.resource.data.active == false
                    && request.resource.data.role in ['admin','staff'];
      // 本人は 最終ログイン時刻 / プッシュトークン / 登録端末 のみ更新可(役割・所属などは変更不可)
      // 端末数は deviceLimit(既定2)まで。deviceLimit 自体は本人には変更させない(=有料枠の付与は下の admin/super のみ)。
      allow update: if request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin','fcmTokens','devices'])
                    && request.resource.data.get('devices', []).size() <= resource.data.get('deviceLimit', 2);
      // 承認/無効化: super は全員、admin は自社のみ
      allow delete: if isSuper() || (isAdmin() && resource.data.tenantId == myTenant());
      // 更新も同様。ただし有料枠(deviceLimit)の変更は super のみ(代表管理者=adminによる無料付与を防止)
      allow update: if isSuper()
                    || (isAdmin() && resource.data.tenantId == myTenant()
                        && request.resource.data.get('deviceLimit', 2) == resource.data.get('deviceLimit', 2));
    }

    // 契約の申し込み(請求書送付先メール等)。所属者が自社分を作成、運営が閲覧/更新。
    match /signups/{id} {
      allow create: if meActive() && request.resource.data.tenantId == myTenant();
      allow read, update, delete: if isSuper();
    }

    match /tenants/{tid} {
      allow read: if signedIn();
      allow create: if signedIn() && (request.resource.data.active == false || isOwner());
      allow update, delete: if isSuper();
    }

    match /tenants/{tid}/{coll}/{doc} {
      allow read, write: if meActive() && (myTenant() == tid || isSuper());
    }
  }
}
