# これをコピーして functions/.env を作り、値を実際の鍵に置き換えてください。
# functions/.env は絶対に git にコミットしないこと（.gitignore 済み）。
# 記入後: firebase deploy --only functions

# メカ君用 Gemini APIキー（Google AI Studioで発行）
GEMINI_KEY=AIza-xxxxxxxxxxxxxxxx

# 文字読み取り用 Cloud Vision APIキー（Google CloudでVision API有効化して発行）
VISION_KEY=AIza-xxxxxxxxxxxxxxxx

# Stripe シークレットキー（Stripe → 開発者 → APIキー）。sk_test_ から始めてテスト、後で sk_live_ に。
STRIPE_SECRET=sk_test_xxxxxxxxxxxxxxxx

# Stripe Webhook 署名シークレット（Stripe → 開発者 → Webhook でエンドポイント作成後に表示）
STRIPE_WH=whsec_xxxxxxxxxxxxxxxx

# Stripe の価格ID（商品に月額・年額の2つのPriceを作り、その price_ を貼る）
STRIPE_PRICE_MONTH=price_xxxxxxxxxxxx
STRIPE_PRICE_YEAR=price_xxxxxxxxxxxx

# 支払い完了後に戻るアプリのURL
APP_URL=https://tomo-design.github.io/shakensho-scan/
